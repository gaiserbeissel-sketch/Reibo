# 复制为 .env 后按需修改。步骤4（混剪/合成）常用项：
#
# --- 编码：NVENC（RTX 等）---
# auto=探测到 h264_nvenc 且 CUDA 可用则用 GPU，否则 libx264
FFMPEG_VIDEO_ENCODER=auto
# 步骤4 成片 NVENC 预设：p1 最快 … p7 最慢质量更好
FFMPEG_COMPOSE_NVENC_PRESET=p4
# CQ 越大体积越小、略糊；与 fast_mode 二选一权衡
FFMPEG_COMPOSE_NVENC_CQ=24
# 可选：NVENC -tune（ffmpeg 文档：hq / ll / ull / lossless）；留空不传
# FFMPEG_COMPOSE_NVENC_TUNE=hq
# True 时强制 p1、抬高 CQ（牺牲画质换速度）
COMPOSE_FAST_MODE=false

# --- 解码：输入侧 -hwaccel cuda（NVDEC）---
# auto=短解码探测通过则启用；on=强制尝试；off=关闭
COMPOSE_HWACCEL_CUDA=auto

# --- 字幕：CPU 烧录较重，速度优先可只导出 SRT ---
COMPOSE_BURN_SUBTITLES_INTO_VIDEO=true

# --- 步骤4 成片播放速度：1.0=原速；1.2=更快、时长更短（画面 setpts + 口播 atempo；SRT 随成片对齐）---
COMPOSE_OUTPUT_PLAYBACK_SPEED=1.2

# --- 代理素材（draft 对位 / 终渲换原片需自备文件）---
COMPOSE_PROXY_REWRITE_ENABLED=false
# 例：将 /static-data/video/ 映射到 /static-data/video_proxy/
COMPOSE_PROXY_PATH_PREFIX=
COMPOSE_PROXY_PATH_REPLACE=
COMPOSE_PROXY_DEFAULT_ON=false

# --- 步骤3：ComfyUI + LivePortrait（可选；与 Wav2Lip 二选一）---
# AVATAR_RENDER_BACKEND=liveportrait_comfy
# COMFYUI_BASE_URL=http://127.0.0.1:8188
# COMFYUI_INSTALL_ROOT=/path/to/ComfyUI
# 从 ComfyUI 导出 API 格式工作流 JSON 的路径（相对仓库根或绝对路径）
# COMFYUI_LIVEPORTRAIT_WORKFLOW_PATH=tools/comfyui_workflows/liveportrait_api.json
# API 工作流中要写入「源图」「驱动视频」的节点 ID（字符串键，如 "12"）
# COMFYUI_LP_NODE_SOURCE_IMAGE=
# COMFYUI_LP_NODE_DRIVE_VIDEO=
# COMFYUI_LP_SOURCE_INPUT_KEY=image
# COMFYUI_LP_DRIVE_INPUT_KEY=video
# 可选：优先从该节点 outputs 取成片
# COMFYUI_LP_OUTPUT_NODE=
# COMFYUI_LIVEPORTRAIT_TIMEOUT_S=3600
